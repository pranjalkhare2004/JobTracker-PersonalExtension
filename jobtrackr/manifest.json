{
  "manifest_version": 3,
  "name": "JobTrackr",
  "version": "1.0.0",
  "description": "Track job applications across LinkedIn, Wellfound, Indeed, Naukri & more. One-click logging, dedup detection, and a full dashboard — all stored locally.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://wellfound.com/*",
    "https://angel.co/*",
    "https://www.indeed.com/*",
    "https://www.naukri.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "JobTrackr — Log this application"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://wellfound.com/*",
        "https://angel.co/*",
        "https://www.indeed.com/*",
        "https://www.naukri.com/*"
      ],
      "js": ["scraper.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+J",
        "mac": "Command+Shift+J"
      },
      "description": "Open JobTrackr popup"
    }
  }
}
