{
  "manifest_version": 3,
  "name": "JobTrackr",
  "version": "2.0.0",
  "description": "Track job applications across any ATS — Workday, Greenhouse, Lever, LinkedIn, Indeed, and more. One-click logging with auto-fill, dedup detection, JD keyword extraction, and smart referral messages.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://wellfound.com/*",
    "https://angel.co/*",
    "https://www.indeed.com/*",
    "https://www.naukri.com/*",
    "https://boards.greenhouse.io/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://jobs.smartrecruiters.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.myworkday.com/*",
    "https://*.ashbyhq.com/*",
    "https://*.rippling.com/*",
    "https://*.icims.com/*",
    "https://*.bamboohr.com/*",
    "https://*.jobvite.com/*",
    "https://*.breezy.hr/*",
    "https://*.workable.com/*",
    "https://*.taleo.net/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "JobTrackr — Log this application"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scraper.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+J",
        "mac": "Command+Shift+J"
      },
      "description": "Open JobTrackr popup"
    }
  }
}
